# Copy this file to scripts/.env.seed and fill in the values, then run:
#   node scripts/seed-founder.mjs
# No quotes needed, even for spaces or parentheses. scripts/.env.seed is gitignored.

# From your .env (EXPO_PUBLIC_SUPABASE_URL), e.g. https://xxxx.supabase.co
SUPABASE_URL=

# Supabase dashboard: Project Settings > API > service_role secret. Never commit this.
SUPABASE_SERVICE_ROLE_KEY=

FOUNDER_EMAIL=email@gmail.com
FOUNDER_PASSWORD=password
FOUNDER_USERNAME=elijahtanblue
FOUNDER_DISPLAY_NAME=Elijah Tan (founder)
